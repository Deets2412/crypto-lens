# ============================================================
# CoinDebrief — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Stripe Price IDs (create these in your Stripe Dashboard)
STRIPE_PRICE_NORMIE=price_xxx
STRIPE_PRICE_NIGHT_OWL=price_xxx
STRIPE_PRICE_COIN_SENSE=price_xxx

# Resend (for daily email briefings)
RESEND_API_KEY=re_your-resend-api-key

# Vercel Cron Secret (auto-generated by Vercel, or set your own)
CRON_SECRET=your-cron-secret-string

# Perplexity Sonar API (for AI Intelligence features)
# Get your key: https://docs.perplexity.ai → API Settings
# Or install via Vercel Marketplace: https://vercel.com/marketplace/pplx-api
PERPLEXITY_API_KEY=pplx-your-api-key-here
